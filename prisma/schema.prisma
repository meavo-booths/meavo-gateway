generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  ADMIN
  USER
}

enum TeamRole {
  MANAGER
  MEMBER
}

enum Company {
  MEAVO
  OA
}

model CompanyProfile {
  company       Company  @id
  legalName     String   @default("")
  legalNameBg   String   @default("")
  address       String   @default("")
  addressBg     String   @default("")
  companyNumber String   @default("")
  vatNumber     String   @default("")
  deVatNumber   String   @default("")
  eori          String   @default("")
  manager       String   @default("")
  managerBg     String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum ContractType {
  FTE
  FREELANCE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  systemRole    SystemRole @default(USER)
  hrAccess      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts           Account[]
  teamMembers        TeamMember[]
  cardAccess         ToolCardAccess[]
  employee           Employee?
  vacationRequests   VacationRequest[] @relation("Requester")
  reviewedRequests   VacationRequest[] @relation("Reviewer")
  allowances         UserAllowance[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Team {
  id              String       @id @default(cuid())
  name            String       @unique
  color           String       @default("#EEDCDC")
  yearlyAllowance Int          @default(25)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  members         TeamMember[]
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(MEMBER)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model ToolCard {
  id          String           @id @default(cuid())
  name        String
  description String
  url         String
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  access      ToolCardAccess[]
}

model ToolCardAccess {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card ToolCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model Employee {
  id        String       @id @default(cuid())
  userId    String       @unique
  company   Company
  contract  ContractType
  startDate DateTime     @db.Date
  endDate   DateTime?    @db.Date
  role      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents EmployeeDocument[]
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  fileName   String
  mimeType   String
  storageKey String
  uploadedBy String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// Vacation Tracker–specific (shared DB — gateway does not use these directly)
model UserAllowance {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  days      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

model VacationRequest {
  id           String        @id @default(cuid())
  userId       String
  startDate    DateTime
  endDate      DateTime
  days         Float
  note         String?
  status       RequestStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User  @relation("Requester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("Reviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

DATABASE_URL="postgresql://user:password@localhost:5432/meavo_gateway"

AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Navigation / tool switcher
MEAVO_APP_KEY="gateway"
GATEWAY_URL="http://localhost:3000"

# Google sign-in (optional — button hidden if unset)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

ADMIN_EMAILS="you@company.com"
ADMIN_PASSWORD="change-me-in-production"

# Only this user can grant/revoke HR access (optional — unset means admins can)
HR_ACCESS_GRANTOR_EMAIL=""

# Marketing team members who can upload/replace the Market Dashboard (team ID from Admin → Teams)
MARKETING_TEAM_ID=""

# Vercel Blob — required for HR contract PDF uploads
BLOB_READ_WRITE_TOKEN=""

# Email notifications (gateway processes outbox; hols/assembly only enqueue)
RESEND_API_KEY=""
EMAIL_FROM="MEAVO <notifications@meavo.app>"
CRON_SECRET="generate-with: openssl rand -base64 32"
# Optional in development — redirect all notification emails to one inbox
EMAIL_DEV_OVERRIDE=""

# Google Sheets import (same service account as assembly — share the sheet with its client_email as Viewer)
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_TAB_NAME="Sheet1"
GOOGLE_SERVICE_ACCOUNT_JSON=""

# Slack notifications (bot DMs — requires chat:write, im:write, users:read.email)
SLACK_BOT_TOKEN=""
# Weekly approved-leave digest posted to a Slack channel via incoming webhook
SLACK_HOLIDAY_DIGEST_WEBHOOK_URL=""
HOLIDAY_DIGEST_ENABLED="true"
HOLIDAY_DIGEST_TIMEZONE="Europe/London"

# Satellite app URLs used in notification links (optional — sensible defaults)
HOLS_URL="https://hols.meavo.app"
ASSEMBLY_URL="https://assembly.meavo.app"
SALES_URL="https://sales.meavo.app"
TASKS_URL="https://tasks.meavo.app"
